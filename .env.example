# Copy this file to .env and fill your real values.

# Shared defaults are optional.
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=3
OPENAI_MAX_TOKENS=512

# Generator model: generates related variant questions.
GENERATOR_MODEL_NAME=gpt-5.4
GENERATOR_MODEL_BASE_URL=https://reelxai.com/v1
GENERATOR_MODEL_API_KEY=
GENERATOR_MODEL_API_PROTOCOL=responses

# Optimizer model: rewrites the system prompt for failed answer models.
OPTIMIZER_MODEL_NAME=gpt-5.4
OPTIMIZER_MODEL_BASE_URL=https://reelxai.com/v1
OPTIMIZER_MODEL_API_KEY=
OPTIMIZER_MODEL_API_PROTOCOL=responses

# Answer models: every generated variant will be answered by all listed models.
# Put the slot ids here, then fill ANSWER_MODEL_<id>_* below.
ANSWER_MODEL_IDS=1,2,3,4

# Optional shared answer-model settings.
ANSWER_MODEL_SHARED_BASE_URL=https://reelxai.com/v1
ANSWER_MODEL_SHARED_API_KEY=

ANSWER_MODEL_1_NAME=
ANSWER_MODEL_1_API_PROTOCOL=chat_completions

ANSWER_MODEL_2_NAME=
ANSWER_MODEL_2_API_PROTOCOL=chat_completions

ANSWER_MODEL_3_NAME=
ANSWER_MODEL_3_API_PROTOCOL=chat_completions

ANSWER_MODEL_4_NAME=
ANSWER_MODEL_4_API_PROTOCOL=chat_completions
